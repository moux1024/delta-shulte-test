<view class="page">
  <view class="report-hero">
    <view class="hero-topline">
      <text class="hero-label">认知画像</text>
      <text class="hero-grade" style="color: {{grade.color}}">{{grade.level}}</text>
    </view>
    <text class="profile-name">{{profile.name}}</text>
    <text class="profile-summary">{{profile.summary}}</text>
    <view class="hero-meta-row">
      <view class="hero-meta-item">
        <text class="hero-meta-label">完成时间</text>
        <text class="hero-meta-value">{{timeStr}}</text>
      </view>
      <view class="hero-meta-item">
        <text class="hero-meta-label">推荐打法</text>
        <text class="hero-meta-value">{{primaryRole.style}}</text>
      </view>
    </view>
  </view>

  <view class="tag-row">
    <text class="tag" wx:for="{{tags}}" wx:key="*this">{{item}}</text>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">类型解读</text>
    </view>
    <view class="type-interpretation">
      <text class="type-title">{{profile.name}}</text>
      <text class="type-text">{{selectedTypeInterpretation.text}}</text>
    </view>
  </view>

  <view class="section operator-section">
    <view class="section-header">
      <text class="section-title">干员推荐</text>
    </view>
    <view class="operator-card" wx:for="{{operatorList}}" wx:key="codename">
      <view class="operator-rank">No.{{index + 1}}</view>
      <view class="operator-head">
        <view>
          <text class="operator-name">{{item.codename}}</text>
          <text class="operator-meta">{{item.name}} / {{item.className}}</text>
        </view>
        <view class="match-pill" style="border-color: {{item.color}}; color: {{item.color}}">
          {{item.match}}%
        </view>
      </view>
      <text class="operator-reason">{{item.reason}}</text>
      <text class="operator-ability">{{item.ability}}</text>
    </view>
  </view>

  <view class="radar-card section">
    <view class="section-header">
      <text class="section-title">舒尔特五维雷达</text>
    </view>
    <view class="radar-container">
      <canvas canvas-id="radarCanvas" id="radarCanvas" class="radar-canvas" type="2d"></canvas>
    </view>
  </view>

  <button class="btn-start" bindtap="retry" hover-class="btn-pressed" hover-stay-time="0">再测一次</button>
  <button class="btn-share" open-type="share" hover-class="option-pressed" hover-stay-time="0">分享报告</button>
</view>
