.page {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 360rpx;
}

/* 结果 Hero */
.result-hero {
  text-align: center;
  padding: 48rpx 20rpx 32rpx;
}

.result-badge {
  display: inline-block;
  font-size: 40rpx;
  font-weight: 900;
  padding: 12rpx 40rpx;
  border-radius: 16rpx;
  border: 2rpx solid;
  margin-bottom: 16rpx;
}

.result-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.result-time {
  display: block;
  font-size: 56rpx;
  font-weight: 900;
  color: var(--accent);
  margin-bottom: 12rpx;
}

.result-score-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 4rpx;
}

.result-score {
  display: block;
  font-size: 72rpx;
  font-weight: 900;
}

/* 通用卡片 */
.card {
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: 20rpx;
  padding: 36rpx;
  margin: 24rpx 0;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

/* 雷达图 */
.radar-card {
  text-align: center;
}

.radar-container {
  display: flex;
  justify-content: center;
  padding: 10rpx 0;
}

.radar-canvas {
  width: 500rpx;
  height: 500rpx;
}

/* 维度分析 */
.dim-item {
  margin-bottom: 28rpx;
}

.dim-item:last-child {
  margin-bottom: 0;
}

.dim-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.dim-left {
  display: flex;
  align-items: center;
}

.dim-icon {
  font-size: 30rpx;
  margin-right: 10rpx;
}

.dim-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.dim-value {
  font-size: 28rpx;
  font-weight: 700;
}

.dim-bar-bg {
  height: 12rpx;
  background: var(--card-border);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.dim-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.8s ease;
}

.dim-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

/* 优势/待提升 */
.strengths-weaknesses {
}

.sw-section {
  margin-bottom: 16rpx;
}

.sw-section:last-child {
  margin-bottom: 0;
}

.sw-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.sw-item {
  margin-bottom: 12rpx;
}

.sw-item:last-child {
  margin-bottom: 0;
}

.sw-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.sw-divider {
  height: 1rpx;
  background: var(--card-border);
  margin: 20rpx 0;
}

/* 建议 */
.advice-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.advice-item:last-child {
  margin-bottom: 0;
}

.advice-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  min-width: 40rpx;
}

.advice-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* 科学解读 */
.science-text {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.science-text:last-child {
  margin-bottom: 0;
}

/* 按钮 */
.btn-start {
  margin: 40rpx auto 20rpx;
  display: block;
  width: 80%;
  background: linear-gradient(135deg, var(--accent), var(--accent-light));
  color: white !important;
  border: none !important;
  border-radius: 16rpx !important;
  padding: 28rpx 0 !important;
  font-size: 34rpx !important;
  font-weight: 700 !important;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 53, 0.4);
}

.btn-start::after {
  border: none !important;
}

.btn-share {
  margin: 20rpx auto;
  display: block;
  width: 80%;
  background: var(--card-bg) !important;
  color: var(--text-primary) !important;
  border: 2rpx solid var(--card-border) !important;
  border-radius: 16rpx !important;
  padding: 24rpx 0 !important;
  font-size: 30rpx !important;
  font-weight: 600 !important;
}

.btn-share::after {
  border: none !important;
}

/* Banner广告 */
.banner-ad {
  margin-top: 40rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
