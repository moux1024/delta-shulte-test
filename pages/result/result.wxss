.page {
  min-height: 100vh;
  padding: 28rpx;
  padding-bottom: 300rpx;
  box-sizing: border-box;
  background: #f5f7fb;
}

.report-hero {
  padding: 42rpx 4rpx 0rpx;
}

.hero-icon-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 28rpx;
}

.hero-icon {
  width: 220rpx;
  height: 220rpx;
}

.profile-name {
  display: block;
  color: var(--text-primary);
  font-size: 68rpx;
  font-weight: 900;
  line-height: 1.08;
  margin-bottom: 22rpx;
  text-align: center;
}

.profile-summary {
  display: block;
  color: var(--text-secondary);
  font-size: 30rpx;
  line-height: 1.6;
}

.hero-meta-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 26rpx;
}

.hero-meta-item {
  padding: 22rpx 20rpx;
  background: #ffffff;
  border: 1rpx solid var(--card-border);
  border-radius: 12rpx;
}

.hero-meta-label {
  display: block;
  color: var(--text-muted);
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.hero-meta-value {
  display: block;
  color: var(--text-primary);
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.2;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 6rpx 0 28rpx;
}

.tag {
  color: #1d4ed8;
  background: var(--accent-soft);
  border: 1rpx solid #bfdbfe;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 700;
  padding: 10rpx 18rpx;
}

.section {
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 22rpx 0;
}

.compact-section {
  padding: 26rpx 30rpx;
}

.section-header {
  margin-bottom: 22rpx;
}

.section-title {
  display: block;
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: 850;
  line-height: 1.25;
  margin-top: 4rpx;
}

.operator-rank {
  flex: none;
  color: var(--text-muted);
  background: #f8fafc;
  border: 1rpx solid var(--card-border);
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 800;
  text-align: center;
}

.operator-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.meter {
  width: 100%;
  overflow: hidden;
  background: #eef2f7;
}

.meter {
  height: 10rpx;
  border-radius: 999rpx;
  margin-top: 12rpx;
}

.meter-fill {
  height: 100%;
  border-radius: 999rpx;
}

.operator-section {
  border: none;
  background: transparent;
  padding: 0;
}

.operator-card {
  position: relative;
  padding: 32rpx;
  margin-bottom: 22rpx;
  background: #f8fafc;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
}

.operator-card:last-child {
  margin-bottom: 0;
}

.operator-rank {
  display: inline-block;
  padding: 6rpx 12rpx;
  margin-bottom: 16rpx;
}

.operator-name {
  display: block;
  color: var(--text-primary);
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.15;
}

.operator-meta {
  display: block;
  color: var(--text-muted);
  font-size: 23rpx;
  margin-top: 8rpx;
}

.match-pill {
  flex: none;
  border: 2rpx solid;
  border-radius: 999rpx;
  padding: 12rpx 18rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.operator-reason,
.operator-ability {
  display: block;
  color: var(--text-secondary);
  font-size: 27rpx;
  line-height: 1.55;
}

.operator-reason {
  margin-top: 18rpx;
}

.operator-ability {
  color: #64748b;
  margin-top: 12rpx;
}

.type-interpretation {
  padding: 30rpx;
  background: linear-gradient(135deg, #eff6ff, #ffffff);
  border: 1rpx dashed #93c5fd;
  border-radius: 14rpx;
}

.type-title {
  display: block;
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 850;
  margin-bottom: 10rpx;
}

.type-text {
  display: block;
  color: var(--text-secondary);
  font-size: 36rpx;
  line-height: 1.55;
}

.radar-card {
  text-align: center;
}

.radar-container {
  display: flex;
  justify-content: center;
  padding: 4rpx 0 0;
}

.radar-canvas {
  width: 500rpx;
  height: 500rpx;
}

.btn-start {
  display: block;
  width: 86%;
  border: none !important;
  border-radius: 12rpx !important;
  font-weight: 800 !important;
}

.btn-start {
  margin: 38rpx auto 18rpx;
  color: white !important;
  background: var(--accent);
  padding: 26rpx 0 !important;
  font-size: 32rpx !important;
  box-shadow: 0 8rpx 28rpx rgba(37, 99, 235, 0.24);
}

.btn-start::after {
  border: none !important;
}
