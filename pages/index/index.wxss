.page {
  min-height: 100vh;
  padding: 40rpx 32rpx;
  padding-bottom: 240rpx;
}

/* Hero区域 */
.hero {
  text-align: center;
  padding: 60rpx 20rpx 40rpx;
  position: relative;
}

.hero-badge {
  display: inline-block;
  background: var(--accent-soft);
  color: var(--accent);
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  border: 1rpx solid #bfdbfe;
  margin-bottom: 24rpx;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.3;
  margin-bottom: 16rpx;
}

.hero-subtitle {
  display: block;
  font-size: 30rpx;
  color: var(--accent);
  font-weight: 500;
}

.hero-glow {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(37, 99, 235, 0.08) 0%, transparent 70%);
  pointer-events: none;
}

/* 通用卡片 */
.card {
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: 16rpx;
  padding: 36rpx;
  margin: 24rpx 0;
}

.intro-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.intro-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

/* 规则列表 */
.rule-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.rule-item:last-child {
  margin-bottom: 0;
}

.rule-num {
  width: 48rpx;
  height: 48rpx;
  min-width: 48rpx;
  background: var(--accent-soft);
  color: var(--accent);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 20rpx;
}

.rule-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 48rpx;
}

/* 科学原理 */
.science-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.science-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 难度选择 */
.difficulty-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 24rpx;
}

.difficulty-options {
  display: flex;
  gap: 16rpx;
}

.diff-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: #f8fafc;
  border: 2rpx solid var(--card-border);
  border-radius: 16rpx;
  transition: all 0.3s;
}

.diff-btn.active {
  background: var(--accent-soft);
  border-color: var(--accent);
}

.diff-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.diff-btn.active .diff-name {
  color: var(--accent);
}
.red {
  color: rgba(255, 0, 0, 1)
}
.green {
  color: rgb(7, 77, 7)
}

.diff-desc {
  font-size: 22rpx;
  color: var(--text-muted);
}

.diff-current {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: var(--text-muted);
  font-weight: 600;
}

/* 开始按钮 */
.btn-start {
  margin: 48rpx auto;
  display: block;
  width: 100%;
  background: rgb(7, 77, 7);
  color: white !important;
  border: none !important;
  border-radius: 14rpx !important;
  padding: 28rpx 0 !important;
  font-size: 36rpx !important;
  font-weight: 700 !important;
  box-shadow: 0 8rpx 28rpx rgba(37, 99, 235, 0.24);
  letter-spacing: 0;
}

.btn-start::after {
  border: none !important;
}

.btn-test-result {
  margin: 0 0 16rpx;
  display: block;
  width: 100%;
  box-sizing: border-box;
  text-align: center;
  background: #ffffff;
  color: var(--accent) !important;
  border: 2rpx solid var(--accent) !important;
  border-radius: 12rpx !important;
  padding: 20rpx 0 !important;
  font-size: 26rpx !important;
  font-weight: 700 !important;
  letter-spacing: 0;
}

.test-result-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.test-result-list .btn-test-result:last-child {
  margin-bottom: 16rpx;
}

.btn-test-result::after {
  border: none !important;
}

/* Banner广告 */
.banner-ad {
  margin-top: 40rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
