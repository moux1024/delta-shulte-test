page {
  background-color: #f5f7fb;
  color: #1f2937;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  --accent: #2563eb;
  --accent-light: #38bdf8;
  --accent-soft: #dbeafe;
  --danger: #dc2626;
  --success: #16a34a;
  --warning: #d97706;
  --card-bg: #ffffff;
  --card-border: #e5e7eb;
  --pressed-bg: #dbeafe;
  --text-primary: #111827;
  --text-secondary: #4b5563;
  --text-muted: #8a94a6;
}

/* 通用按钮 */
.btn-primary {
  background: var(--accent);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.22);
}

.btn-pressed {
  background: #1d4ed8 !important;
  color: #ffffff !important;
  transform: scale(0.98);
}

.option-pressed {
  background: var(--pressed-bg) !important;
  border-color: var(--accent) !important;
}

.btn-primary::after {
  border: none;
}

/* 卡片 */
.card {
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: 20rpx;
  padding: 40rpx;
  margin: 20rpx 0;
}
